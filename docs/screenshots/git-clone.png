<svg xmlns="http://www.w3.org/2000/svg" width="800" height="500" viewBox="0 0 800 500">
  <rect fill="#f5f5f5" width="800" height="500"/>

  <!-- 窗口框架 -->
  <rect fill="#0078d4" width="800" height="32"/>
  <text x="15" y="24" fill="white" font-family="Arial" font-size="14">Git Bash - git clone</text>

  <!-- 终端内容 -->
  <rect fill="#0c0c0c" x="10" y="40" width="780" height="450"/>

  <text x="20" y="80" fill="#00ff00" font-family="Consolas" font-size="14">$ git clone https://github.com/keyupan91-cpu/Feishu-erp-bridge.git</text>

  <text x="20" y="120" fill="#cccccc" font-family="Consolas" font-size="13">Cloning into 'Feishu-erp-bridge'...</text>
  <text x="20" y="145" fill="#cccccc" font-family="Consolas" font-size="13">remote: Enumerating objects: 156, done.</text>
  <text x="20" y="170" fill="#cccccc" font-family="Consolas" font-size="13">remote: Counting objects: 100% (156/156), done.</text>
  <text x="20" y="195" fill="#cccccc" font-family="Consolas" font-size="13">remote: Compressing objects: 100% (89/89), done.</text>
  <text x="20" y="220" fill="#cccccc" font-family="Consolas" font-size="13">remote: Total 156 (delta 45), reused 134 (delta 23), pack-reused 0</text>
  <text x="20" y="245" fill="#cccccc" font-family="Consolas" font-size="13">Receiving objects: 100% (156/156), 2.34 MiB | 1.56 MiB/s, done.</text>
  <text x="20" y="270" fill="#cccccc" font-family="Consolas" font-size="13">Resolving deltas: 100% (45/45), done.</text>

  <text x="20" y="320" fill="#00ff00" font-family="Consolas" font-size="14">$ cd Feishu-erp-bridge</text>

  <text x="20" y="360" fill="#00ff00" font-family="Consolas" font-size="14">$ ls</text>

  <text x="20" y="390" fill="#00ffff" font-family="Consolas" font-size="13">
Dockerfile          deploy.bat     package.json     server/
README.md           deploy.sh      public/          src/
docker-compose.yml  docs/          scripts/         tsconfig.json
</text>

  <text x="20" y="450" fill="#00ff00" font-family="Consolas" font-size="14">$</text>
  <rect fill="#00ff00" x="35" y="435" width="10" height="20"/>
</svg>
