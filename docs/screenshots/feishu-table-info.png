<svg xmlns="http://www.w3.org/2000/svg" width="800" height="600" viewBox="0 0 800 600">
  <rect fill="#f5f5f5" width="800" height="600"/>
  <rect fill="#00d6b9" width="800" height="60"/>
  <text x="20" y="40" fill="white" font-family="Arial" font-size="18" font-weight="bold">飞书多维表</text>
  <rect fill="white" x="50" y="100" width="700" height="200" rx="8"/>
  <text x="80" y="150" fill="#333" font-family="Arial" font-size="14">地址栏 URL:</text>
  <rect fill="#f5f5f5" x="80" y="170" width="640" height="50" rx="4"/>
  <text x="95" y="200" fill="#1890ff" font-family="Consolas" font-size="12">https://xxx.feishu.cn/base/bascnXXXXXXXXXXXXX?table=tblXXXXXXXXXXXXX</text>
  <text x="80" y="260" fill="#52c41a" font-family="Arial" font-size="14">✓ App Token: bascnXXXXXXXXXXXXX</text>
  <text x="80" y="290" fill="#52c41a" font-family="Arial" font-size="14">✓ Table ID: tblXXXXXXXXXXXXX</text>
  <text x="400" y="550" fill="#999" font-family="Arial" font-size="14" text-anchor="middle">从多维表 URL 获取 App Token 和 Table ID</text>
</svg>
