<svg xmlns="http://www.w3.org/2000/svg" width="800" height="600" viewBox="0 0 800 600">
  <rect fill="#f5f5f5" width="800" height="600"/>
  <rect fill="#1890ff" width="800" height="60"/>
  <text x="20" y="40" fill="white" font-family="Arial" font-size="18" font-weight="bold">金蝶数据传输平台</text>
  <rect fill="white" x="50" y="100" width="700" height="400" rx="8"/>
  <text x="80" y="150" fill="#333" font-family="Arial" font-size="18" font-weight="bold">创建同步任务</text>
  <text x="80" y="200" fill="#666" font-family="Arial" font-size="14">任务名称：[输入框]</text>
  <text x="80" y="240" fill="#666" font-family="Arial" font-size="14">数据源：飞书多维表</text>
  <text x="80" y="280" fill="#666" font-family="Arial" font-size="14">目标：金蝶云星空</text>
  <text x="80" y="320" fill="#666" font-family="Arial" font-size="14">同步类型：付款单/收款单/采购订单...</text>
  <rect fill="#1890ff" x="300" y="420" width="200" height="50" rx="4"/>
  <text x="400" y="452" fill="white" font-family="Arial" font-size="16" text-anchor="middle">保存并执行</text>
  <text x="400" y="550" fill="#999" font-family="Arial" font-size="14" text-anchor="middle">创建同步任务页面</text>
</svg>
