<svg xmlns="http://www.w3.org/2000/svg" width="800" height="600" viewBox="0 0 800 600">
  <rect fill="#f5f5f5" width="800" height="600"/>

  <!-- 浏览器框架 -->
  <rect fill="#e8e8e8" width="800" height="40"/>
  <circle fill="#ff5f57" cx="15" cy="20" r="6"/>
  <circle fill="#ffbd2e" cx="35" cy="20" r="6"/>
  <circle fill="#28c940" cx="55" cy="20" r="6"/>
  <rect fill="#fff" x="80" y="8" width="640" height="24" rx="4"/>
  <text x="400" y="24" fill="#999" font-family="Arial" font-size="12" text-anchor="middle">http://localhost:5173/config</text>

  <!-- 侧边栏 -->
  <rect fill="#001529" width="200" height="600"/>
  <text x="100" y="100" fill="#fff" font-family="Arial" font-size="16" text-anchor="middle">配置中心</text>
  <rect fill="#1890ff" x="0" y="150" width="200" height="45"/>
  <text x="100" y="178" fill="#fff" font-family="Arial" font-size="14" text-anchor="middle">飞书配置</text>
  <rect fill="#001529" x="0" y="195" width="200" height="45"/>
  <text x="100" y="223" fill="#a6adb4" font-family="Arial" font-size="14" text-anchor="middle">金蝶配置</text>
  <rect fill="#001529" x="0" y="240" width="200" height="45"/>
  <text x="100" y="268" fill="#a6adb4" font-family="Arial" font-size="14" text-anchor="middle">任务配置</text>

  <!-- 主内容区 -->
  <rect fill="white" x="200" y="40" width="600" height="560"/>

  <!-- 标题 -->
  <text x="230" y="100" fill="#333" font-family="Arial" font-size="20" font-weight="bold">飞书配置</text>

  <!-- 表单 -->
  <text x="230" y="150" fill="#666" font-family="Arial" font-size="14">App ID</text>
  <rect fill="#f5f5f5" x="230" y="165" width="550" height="40" rx="4"/>
  <text x="245" y="190" fill="#ccc" font-family="Arial" font-size="14">cli_xxxxxxxxxxxxxxxx</text>

  <text x="230" y="230" fill="#666" font-family="Arial" font-size="14">App Secret</text>
  <rect fill="#f5f5f5" x="230" y="245" width="550" height="40" rx="4"/>
  <text x="245" y="270" fill="#ccc" font-family="Arial" font-size="14">••••••••••••••••</text>

  <text x="230" y="310" fill="#666" font-family="Arial" font-size="14">App Token</text>
  <rect fill="#f5f5f5" x="230" y="325" width="550" height="40" rx="4"/>
  <text x="245" y="350" fill="#ccc" font-family="Arial" font-size="14">bascnxxxxxxxxxxxxxx</text>

  <text x="230" y="390" fill="#666" font-family="Arial" font-size="14">Table ID</text>
  <rect fill="#f5f5f5" x="230" y="405" width="550" height="40" rx="4"/>
  <text x="245" y="430" fill="#ccc" font-family="Arial" font-size="14">tblxxxxxxxxxxxxxx</text>

  <!-- 测试按钮 -->
  <rect fill="#52c41a" x="230" y="470" width="120" height="40" rx="4"/>
  <text x="290" y="497" fill="white" font-family="Arial" font-size="14" text-anchor="middle">测试连接</text>

  <rect fill="#1890ff" x="370" y="470" width="120" height="40" rx="4"/>
  <text x="430" y="497" fill="white" font-family="Arial" font-size="14" text-anchor="middle">保存配置</text>

  <!-- 成功提示 -->
  <rect fill="#f6ffed" x="230" y="530" width="200" height="35" rx="4"/>
  <rect fill="#b7eb8f" x="245" y="540" width="20" height="20" rx="10"/>
  <text x="255" y="555" fill="#52c41a" font-family="Arial" font-size="16" text-anchor="middle">✓</text>
  <text x="280" y="553" fill="#52c41a" font-family="Arial" font-size="14">连接成功</text>
</svg>
