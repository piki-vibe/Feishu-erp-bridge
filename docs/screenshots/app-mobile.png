<svg xmlns="http://www.w3.org/2000/svg" width="375" height="812" viewBox="0 0 375 812">
  <rect fill="#f5f5f5" width="375" height="812"/>

  <!-- 手机顶部状态栏 -->
  <rect fill="#1890ff" width="375" height="44"/>
  <text x="187" y="28" fill="white" font-family="Arial" font-size="14" text-anchor="middle" font-weight="bold">金蝶数据传输</text>

  <!-- 用户信息 -->
  <rect fill="#1890ff" width="375" height="120"/>
  <text x="20" y="80" fill="white" font-family="Arial" font-size="16">你好，管理员</text>
  <text x="20" y="105" fill="#e6f7ff" font-family="Arial" font-size="12">上次登录：2026-03-06 10:30</text>

  <!-- 统计卡片 -->
  <rect fill="white" x="15" y="135" width="105" height="70" rx="8"/>
  <text x="67" y="165" fill="#1890ff" font-family="Arial" font-size="24" font-weight="bold" text-anchor="middle">128</text>
  <text x="67" y="185" fill="#666" font-family="Arial" font-size="12" text-anchor="middle">总任务</text>

  <rect fill="white" x="135" y="135" width="105" height="70" rx="8"/>
  <text x="187" y="165" fill="#52c41a" font-family="Arial" font-size="24" font-weight="bold" text-anchor="middle">125</text>
  <text x="187" y="185" fill="#666" font-family="Arial" font-size="12" text-anchor="middle">成功</text>

  <rect fill="white" x="255" y="135" width="105" height="70" rx="8"/>
  <text x="307" y="165" fill="#fa8c16" font-family="Arial" font-size="24" font-weight="bold" text-anchor="middle">3</text>
  <text x="307" y="185" fill="#666" font-family="Arial" font-size="12" text-anchor="middle">失败</text>

  <!-- 任务列表标题 -->
  <text x="20" y="240" fill="#333" font-family="Arial" font-size="16" font-weight="bold">任务列表</text>

  <!-- 任务卡片 1 -->
  <rect fill="white" x="15" y="255" width="345" height="80" rx="8"/>
  <rect fill="#52c41a" x="25" y="265" width="50" height="20" rx="3"/>
  <text x="50" y="280" fill="white" font-family="Arial" font-size="10" text-anchor="middle">已启用</text>
  <text x="90" y="280" fill="#333" font-family="Arial" font-size="14" font-weight="bold">付款单同步</text>
  <text x="90" y="305" fill="#999" font-family="Arial" font-size="11">飞书 → 金蝶</text>
  <text x="300" y="295" fill="#1890ff" font-family="Arial" font-size="12" text-anchor="middle">执行</text>

  <!-- 任务卡片 2 -->
  <rect fill="white" x="15" y="345" width="345" height="80" rx="8"/>
  <rect fill="#d9d9d9" x="25" y="355" width="50" height="20" rx="3"/>
  <text x="50" y="370" fill="#666" font-family="Arial" font-size="10" text-anchor="middle">已禁用</text>
  <text x="90" y="370" fill="#333" font-family="Arial" font-size="14" font-weight="bold">销售订单同步</text>
  <text x="90" y="395" fill="#999" font-family="Arial" font-size="11">飞书 → 金蝶</text>
  <text x="300" y="385" fill="#1890ff" font-family="Arial" font-size="12" text-anchor="middle">执行</text>

  <!-- 任务卡片 3 -->
  <rect fill="white" x="15" y="435" width="345" height="80" rx="8"/>
  <rect fill="#52c41a" x="25" y="445" width="50" height="20" rx="3"/>
  <text x="50" y="460" fill="white" font-family="Arial" font-size="10" text-anchor="middle">已启用</text>
  <text x="90" y="460" fill="#333" font-family="Arial" font-size="14" font-weight="bold">采购订单同步</text>
  <text x="90" y="485" fill="#999" font-family="Arial" font-size="11">飞书 → 金蝶</text>
  <text x="300" y="475" fill="#1890ff" font-family="Arial" font-size="12" text-anchor="middle">执行</text>

  <!-- 底部导航 -->
  <rect fill="white" y="750" width="375" height="62"/>
  <rect fill="#e6f7ff" y="750" width="375" height="1"/>
  <text x="62" y="785" fill="#1890ff" font-family="Arial" font-size="12" text-anchor="middle">任务</text>
  <text x="187" y="785" fill="#999" font-family="Arial" font-size="12" text-anchor="middle">记录</text>
  <text x="312" y="785" fill="#999" font-family="Arial" font-size="12" text-anchor="middle">我的</text>

  <!-- 悬浮按钮 -->
  <circle fill="#1890ff" cx="330" cy="700" r="25"/>
  <text x="330" y="710" fill="white" font-family="Arial" font-size="28" text-anchor="middle" font-weight="bold">+</text>
</svg>
