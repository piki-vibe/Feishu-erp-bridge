<svg xmlns="http://www.w3.org/2000/svg" width="800" height="600" viewBox="0 0 800 600">
  <rect fill="white" width="800" height="600"/>

  <!-- 标题 -->
  <text x="40" y="60" fill="#333" font-family="Arial" font-size="24" font-weight="bold"> docs/screenshots/ 目录说明</text>

  <!-- 文件列表 -->
  <text x="40" y="120" fill="#1890ff" font-family="Consolas" font-size="16">app-preview.png</text>
  <text x="40" y="145" fill="#666" font-family="Arial" font-size="14">- PC 端应用主界面（任务列表）</text>

  <text x="40" y="185" fill="#1890ff" font-family="Consolas" font-size="16">app-mobile.png</text>
  <text x="40" y="210" fill="#666" font-family="Arial" font-size="14">- 移动端应用界面（任务列表）</text>

  <text x="40" y="250" fill="#1890ff" font-family="Consolas" font-size="16">deploy-windows.png</text>
  <text x="40" y="275" fill="#666" font-family="Arial" font-size="14">- Windows 部署脚本运行截图</text>

  <text x="40" y="315" fill="#1890ff" font-family="Consolas" font-size="16">git-clone.png</text>
  <text x="40" y="340" fill="#666" font-family="Arial" font-size="14">- Git 克隆仓库截图</text>

  <text x="40" y="380" fill="#1890ff" font-family="Consolas" font-size="16">docker-build.png</text>
  <text x="40" y="405" fill="#666" font-family="Arial" font-size="14">- Docker 构建和运行日志</text>

  <text x="40" y="445" fill="#1890ff" font-family="Consolas" font-size="16">login-page.png</text>
  <text x="40" y="470" fill="#666" font-family="Arial" font-size="14">- 用户登录页面</text>

  <text x="40" y="510" fill="#1890ff" font-family="Consolas" font-size="16">feishu-config.png</text>
  <text x="40" y="535" fill="#666" font-family="Arial" font-size="14">- 飞书配置页面</text>

  <text x="40" y="575" fill="#1890ff" font-family="Consolas" font-size="16">cloudflare-tunnel.png</text>
  <text x="40" y="600" fill="#666" font-family="Arial" font-size="14">- Cloudflare Tunnel 启动成功</text>
</svg>
